# DB, JWT 등 기존 설정은 프로젝트에 맞게 유지

# SMS 인증 (회원가입·연락처 수정 시)
# true: 네이버 SENS로 인증번호 발송 후 인증 완료 필수
# false: 인증 없이 전화번호만 입력해도 가입 가능 (개발용)
SMS_VERIFICATION_ENABLED=true

# 네이버 클라우드 SENS (Simple & Easy Notification Service)
# SENS 콘솔에서 프로젝트 생성 후 발신 프로필·SMS 서비스 생성
NCP_ACCESS_KEY=your_ncp_access_key
NCP_SECRET_KEY=your_ncp_secret_key
NCP_SMS_SERVICE_ID=your_sms_service_id
NCP_SMS_SENDER=01012345678
