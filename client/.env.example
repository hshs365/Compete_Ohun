# API Base URL (로컬 개발)
# 배포 시: 프론트와 백엔드가 다른 도메인이면 반드시 백엔드 주소로 설정해야
# 프로필/업로드 이미지가 로드됩니다. (설정 안 하면 이미지 404 → 깨진 이미지)
# 예: VITE_API_BASE_URL=https://api.allcourtplay.com
VITE_API_BASE_URL=http://localhost:3000

# SMS 인증 활성화 여부 (서버 SMS_VERIFICATION_ENABLED와 동일하게 설정)
# false: 회원가입 시 인증번호 없이 진행 (개발용)
# true: 회원가입 시 네이버 SENS 인증번호 발송·검증 필수 (운영 권장)
VITE_SMS_VERIFICATION_ENABLED=true

# 카카오 OAuth (선택)
VITE_KAKAO_REST_API_KEY=your_kakao_rest_api_key
